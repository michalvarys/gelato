<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="s_gelato_hero" name="Gelato Hero">
    <section class="s_gelato_hero gl-hero o_cc o_cc5 theme_gelato_page pt0 pb0" id="hero"
             data-gl-interval="6000">
        <!-- Background slides (filled by JS via RPC) -->
        <div class="gl-hero-bg" contenteditable="false"/>

        <div class="gl-hero-overlay"/>
        <div class="gl-hero-grain"/>

        <!-- Centered content -->
        <div class="gl-hero-inner">
            <div class="gl-hero-logos">
                <img src="/theme_gelato/static/src/img/fabrica-gelato-white.png" alt="Fabrica Gelato" class="gl-hero-fabrica"/>
                <img src="/theme_gelato/static/src/img/gelato-logo-white.svg" alt="Gelato!" class="gl-hero-logo" width="472" height="146"/>
            </div>

            <!-- Content slides (filled by JS via RPC) -->
            <div class="gl-hero-slides-wrap" contenteditable="false"/>
        </div>

        <!-- Slide indicator (filled by JS) -->
        <div class="gl-hero-slide-nav" contenteditable="false" id="heroSlideNav"/>

        <!-- Scroll cue -->
        <a href="#proc-gelato" class="gl-scroll-cue">
            <span class="gl-scroll-cue-text">Objevte v&#237;ce</span>
            <span class="gl-scroll-cue-line"/>
        </a>

        <img src="/theme_gelato/static/src/img/zmrzlina.webp" alt="Ruka s kornoutem zmrzliny" class="gl-location-zmrzlina" width="500" height="462" loading="lazy" decoding="async"/>
    </section>
</template>
</odoo>
