<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="s_gelato_inquiry" name="Gelato Inquiry">
    <section class="s_gelato_inquiry gl-inquiry o_cc o_cc5 theme_gelato_page" data-snippet="s_gelato_inquiry" id="poptavka">
        <div class="container gl-inquiry-inner">
            <div class="gl-inquiry-info">
                <h2>M&#225;te z&#225;jem o catering<span>?</span></h2>
                <p>
                    Ud&#283;lejte z va&#353;&#237; akce nezapomenuteln&#253; z&#225;&#382;itek. Svatby, firemn&#237;
                    ve&#269;&#237;rky, festivaly nebo workshopy &#8211; p&#345;ivezeme gelato p&#345;&#237;mo k v&#225;m
                    v&#269;etn&#283; profesion&#225;ln&#237;ho servisu.
                </p>

                <div class="gl-inquiry-features">
                    <div class="gl-inquiry-feature">
                        <div class="gl-inquiry-feature-icon">
                            <svg viewBox="0 0 24 24">
                                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                                <path d="M2 17l10 5 10-5"/>
                                <path d="M2 12l10 5 10-5"/>
                            </svg>
                        </div>
                        <div>
                            <h3>Kompletn&#237; servis</h3>
                            <p>P&#345;ivezeme v&#353;e pot&#345;ebn&#233; v&#269;etn&#283; vybaven&#237;</p>
                        </div>
                    </div>

                    <div class="gl-inquiry-feature">
                        <div class="gl-inquiry-feature-icon">
                            <svg viewBox="0 0 24 24">
                                <circle cx="12" cy="12" r="10"/>
                                <polyline points="12 6 12 12 16 14"/>
                            </svg>
                        </div>
                        <div>
                            <h3>Flexibiln&#237; term&#237;ny</h3>
                            <p>P&#345;izp&#367;sob&#237;me se va&#353;emu programu</p>
                        </div>
                    </div>

                    <div class="gl-inquiry-feature">
                        <div class="gl-inquiry-feature-icon">
                            <svg viewBox="0 0 24 24">
                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                            </svg>
                        </div>
                        <div>
                            <h3>Osobn&#237; p&#345;&#237;stup</h3>
                            <p>Ka&#382;dou akci &#345;e&#353;&#237;me individu&#225;ln&#283;</p>
                        </div>
                    </div>
                </div>
            </div>

            <form class="gl-inquiry-form" action="/gelato/contact" method="POST">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <h3>Vypl&#328;te formul&#225;&#345;</h3>
                <p>Ozveme se v&#225;m do 24 hodin.</p>

                <div class="gl-form-row">
                    <div class="gl-form-group">
                        <label for="name">Jm&#233;no a p&#345;&#237;jmen&#237; *</label>
                        <input type="text" id="name" name="name" placeholder="Jan Nov&#225;k" required="required"/>
                    </div>
                    <div class="gl-form-group">
                        <label for="email">E-mail *</label>
                        <input type="email" id="email" name="email" placeholder="jan@email.cz" required="required"/>
                    </div>
                </div>

                <div class="gl-form-row">
                    <div class="gl-form-group">
                        <label for="phone">Telefon</label>
                        <input type="tel" id="phone" name="phone" placeholder="+420 123 456 789"/>
                    </div>
                    <div class="gl-form-group">
                        <label for="event-type">Typ akce *</label>
                        <select id="event-type" name="event-type" required="required">
                            <option value="" disabled="disabled" selected="selected">Vyberte typ akce</option>
                            <option value="svatba">Svatba</option>
                            <option value="firemni-akce">Firemn&#237; akce</option>
                            <option value="narozeniny">Narozeniny / Oslava</option>
                            <option value="festival">Festival / Ve&#345;ejn&#225; akce</option>
                            <option value="workshop">Workshop</option>
                            <option value="jine">Jin&#233;</option>
                        </select>
                    </div>
                </div>

                <div class="gl-form-row">
                    <div class="gl-form-group">
                        <label for="date">P&#345;edpokl&#225;dan&#253; term&#237;n</label>
                        <input type="date" id="date" name="date"/>
                    </div>
                    <div class="gl-form-group">
                        <label for="guests">Po&#269;et host&#367;</label>
                        <input type="number" id="guests" name="guests" placeholder="cca 50" min="1"/>
                    </div>
                </div>

                <div class="gl-form-group">
                    <label for="message">Zpr&#225;va</label>
                    <textarea id="message" name="message" placeholder="Popi&#353;te n&#225;m va&#353;i akci, m&#237;sto kon&#225;n&#237; a dal&#353;&#237; detaily..."></textarea>
                </div>

                <button type="submit" class="gl-btn-submit">
                    Odeslat popt&#225;vku
                    <svg viewBox="0 0 24 24">
                        <line x1="22" y1="2" x2="11" y2="13"/>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                    </svg>
                </button>

                <p class="gl-form-note">
                    * Povinn&#233; pole. Va&#353;e &#250;daje zpracov&#225;v&#225;me v souladu s GDPR.
                </p>
            </form>
        </div>
    </section>
</template>
</odoo>
