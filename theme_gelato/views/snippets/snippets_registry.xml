<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="gelato_snippets" inherit_id="website.snippets" name="Gelato Snippets">
    <xpath expr="//snippets[@id='snippet_structure']" position="after">
        <snippets id="gelato_snippet_structure" string="Gelato">
            <t t-snippet="theme_gelato.s_gelato_hero" t-thumbnail="/theme_gelato/static/src/img/snippets/s_gelato_hero.png"/>
            <t t-snippet="theme_gelato.s_gelato_why" t-thumbnail="/theme_gelato/static/src/img/snippets/s_gelato_why.png"/>
            <t t-snippet="theme_gelato.s_gelato_gallery" t-thumbnail="/theme_gelato/static/src/img/snippets/s_gelato_gallery.png"/>
            <t t-snippet="theme_gelato.s_gelato_reviews" t-thumbnail="/theme_gelato/static/src/img/snippets/s_gelato_reviews.png"/>
            <t t-snippet="theme_gelato.s_gelato_location" t-thumbnail="/theme_gelato/static/src/img/snippets/s_gelato_location.png"/>
            <t t-snippet="theme_gelato.s_gelato_map" t-thumbnail="/theme_gelato/static/src/img/snippets/s_gelato_map.png"/>
            <t t-snippet="theme_gelato.s_gelato_inquiry" t-thumbnail="/theme_gelato/static/src/img/snippets/s_gelato_inquiry.png"/>
            <t t-snippet="theme_gelato.s_gelato_cta" t-thumbnail="/theme_gelato/static/src/img/snippets/s_gelato_cta.png"/>
        </snippets>
    </xpath>
</template>
</odoo>
