<?xml version="1.0" encoding="UTF-8"?>
<odoo>

<record id="view_gelato_hero_slide_list" model="ir.ui.view">
    <field name="name">gelato.hero.slide.list</field>
    <field name="model">gelato.hero.slide</field>
    <field name="arch" type="xml">
        <list open_form_view="True">
            <field name="sequence" widget="handle"/>
            <field name="name" string="Badge"/>
            <field name="headline"/>
            <field name="image" widget="image" options="{'size': [80, 50]}"/>
            <field name="active"/>
            <field name="website_id" groups="website.group_multi_website"/>
        </list>
    </field>
</record>

<record id="view_gelato_hero_slide_form" model="ir.ui.view">
    <field name="name">gelato.hero.slide.form</field>
    <field name="model">gelato.hero.slide</field>
    <field name="arch" type="xml">
        <form string="Hero Slide">
            <sheet>
                <div class="oe_title">
                    <label for="name" string="Badge text"/>
                    <h1>
                        <field name="name" placeholder="e.g. Vlastní výroba"/>
                    </h1>
                </div>
                <group>
                    <group>
                        <field name="headline" placeholder="e.g. Čerstvé gelato"/>
                        <field name="headline_accent" placeholder="e.g. každý den"/>
                        <field name="subtitle"/>
                    </group>
                    <group>
                        <field name="button_text" placeholder="e.g. Více o výrobě"/>
                        <field name="button_url" placeholder="e.g. #showcase"/>
                        <field name="sequence"/>
                        <field name="active"/>
                        <field name="website_id" groups="website.group_multi_website"/>
                    </group>
                </group>
                <group>
                    <field name="image" widget="image"/>
                </group>
            </sheet>
        </form>
    </field>
</record>

<record id="action_gelato_hero_slide" model="ir.actions.act_window">
    <field name="name">Hero Slides</field>
    <field name="res_model">gelato.hero.slide</field>
    <field name="view_mode">list,form</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            Add your first hero slide
        </p>
        <p>
            Configure the slides displayed in the hero section of your website homepage.
        </p>
    </field>
</record>

<menuitem id="menu_gelato_hero_slide"
    name="Hero Slides"
    parent="website.menu_website_global_configuration"
    action="action_gelato_hero_slide"
    sequence="50"/>

</odoo>
