<?xml version="1.0" encoding="UTF-8"?>
<odoo>

<record id="view_gelato_gallery_image_list" model="ir.ui.view">
    <field name="name">gelato.gallery.image.list</field>
    <field name="model">gelato.gallery.image</field>
    <field name="arch" type="xml">
        <list open_form_view="True">
            <field name="sequence" widget="handle"/>
            <field name="name"/>
            <field name="image" widget="image" options="{'size': [80, 80]}"/>
            <field name="active"/>
            <field name="website_id" groups="website.group_multi_website"/>
        </list>
    </field>
</record>

<record id="view_gelato_gallery_image_form" model="ir.ui.view">
    <field name="name">gelato.gallery.image.form</field>
    <field name="model">gelato.gallery.image</field>
    <field name="arch" type="xml">
        <form string="Gallery Image">
            <sheet>
                <div class="oe_title">
                    <label for="name" string="Caption"/>
                    <h1>
                        <field name="name" placeholder="e.g. Klasický kelímek"/>
                    </h1>
                </div>
                <group>
                    <group>
                        <field name="sequence"/>
                        <field name="active"/>
                        <field name="website_id" groups="website.group_multi_website"/>
                    </group>
                </group>
                <group>
                    <field name="image" widget="image"/>
                </group>
            </sheet>
        </form>
    </field>
</record>

<record id="action_gelato_gallery_image" model="ir.actions.act_window">
    <field name="name">Gallery</field>
    <field name="res_model">gelato.gallery.image</field>
    <field name="view_mode">list,form</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            Add your first gallery image
        </p>
        <p>
            Upload images to display in the gallery section on your website.
        </p>
    </field>
</record>

<menuitem id="menu_gelato_gallery_image"
    name="Gallery"
    parent="website.menu_website_global_configuration"
    action="action_gelato_gallery_image"
    sequence="51"/>

</odoo>
