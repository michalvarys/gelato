<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>
    <record id="theme_gelato_primary_variables" model="theme.ir.asset">
        <field name="name">Gelato primary variables</field>
        <field name="bundle">web._assets_primary_variables</field>
        <field name="path">theme_gelato/static/src/scss/primary_variables.scss</field>
    </record>

    <record id="theme_gelato_bootstrap_overridden" model="theme.ir.asset">
        <field name="name">Gelato bootstrap overrides</field>
        <field name="bundle">web._assets_frontend_helpers</field>
        <field name="path">theme_gelato/static/src/scss/bootstrap_overridden.scss</field>
    </record>

    <record id="theme_gelato_theme_scss" model="theme.ir.asset">
        <field name="name">Gelato theme</field>
        <field name="bundle">web.assets_frontend</field>
        <field name="path">theme_gelato/static/src/scss/theme.scss</field>
        <field name="sequence">100</field>
    </record>

    <record id="theme_gelato_header_scss" model="theme.ir.asset">
        <field name="name">Gelato header</field>
        <field name="bundle">web.assets_frontend</field>
        <field name="path">theme_gelato/static/src/scss/header.scss</field>
        <field name="sequence">110</field>
    </record>

    <record id="theme_gelato_footer_scss" model="theme.ir.asset">
        <field name="name">Gelato footer</field>
        <field name="bundle">web.assets_frontend</field>
        <field name="path">theme_gelato/static/src/scss/footer.scss</field>
        <field name="sequence">120</field>
    </record>

    <record id="theme_gelato_responsive_scss" model="theme.ir.asset">
        <field name="name">Gelato responsive</field>
        <field name="bundle">web.assets_frontend</field>
        <field name="path">theme_gelato/static/src/scss/responsive.scss</field>
        <field name="sequence">200</field>
    </record>


</data>
</odoo>
